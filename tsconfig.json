{
  "compilerOptions": {
    "target":              "ES2020",
    "module":              "commonjs",
    "strict":              true,
    "esModuleInterop":     true,
    "resolveJsonModule":   true,
    "rootDir":             ".",
    "outDir":              "dist",
    "moduleResolution":    "node",
    "skipLibCheck":        true,
    "ignoreDeprecations":  "6.0"
  },
  "include": ["./scripts", "./test", "./typechain-types"],
  "files":   ["./hardhat.config.ts"]
}
